# ============================================
# AI Prototype Delivery Tool - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ---------- Database ----------
DATABASE_URL=postgresql://postgres:password@localhost:5432/proto

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- JWT ----------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ---------- API Server ----------
API_PORT=4000
API_HOST=0.0.0.0

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4001

# ---------- AI Engine ----------
AI_ENGINE_PORT=8000
AI_PROVIDER=deepseek  # Options: openai, anthropic, deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
AI_MODEL=gpt-4o

# ---------- Socket Server ----------
SOCKET_PORT=4001

# ---------- Sentry (Error Monitoring) ----------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---------- S3 / OSS (Optional for MVP) ----------
S3_BUCKET=proto-snapshots
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ---------- App ----------
APP_NAME=AI Prototype
APP_URL=http://localhost:3000
